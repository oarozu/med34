{% extends '/base.html.twig' %}

{% block body -%}
    <h1>Evaluaciones anteriores</h1>

    <table class="table table-bordered table-striped hidden-mobile" style="width: 95%">
        <thead>
            <tr>
                <th>Id</th>
                <th>Cedula</th>
                <th>Nombres</th>
                <th>Apellidos</th>
                <th>Vinculacion</th>
                <th>Escuela</th>
                <th>Periodo ID</th>
                <th>Final</th>
                <th>Informe</th>
            </tr>
        </thead>
        <tbody>
        {% for entity in periodos %}
            <tr>
                <td>{{ entity.id }}</a></td>
                <td>{{ entity.user.username }}</td>
                <td>{{ entity.user.nombres }}</td>
                <td>{{ entity.user.apellidos }}</td>
                <td>{{ entity.vinculacion }}</td>
                <td>{{ entity.escuela.sigla }}</td>
                <td>{{ entity.periodo }}</td>
                <td>
                {% if entity.evaluacion.final %}
                {{ entity.evaluacion.final|number_format(1, '.', ',') }}
                {% endif %}
                </td>
                <td>
                    <a href="javascript:popUp('{{ path('docente_final', {'id': entity.id }) }}')" class="btn btn-primary btn-xs">Ver... <i class="fa fa-sign-in"></i></a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

 <script>

function popUp(URL) {

    if(typeof(popupWin) != "object" || popupWin.closed)  {
        popupWin = window.open(URL, 'popupWin', 'scrollbars=auto,toolbar=no,menubar=no,status=no,width=1000,height=600, left=100,top=100');
    }
    else{
        popupWin.location.href = URL;
    }
    popupWin.focus();
 }
</script>
    {% endblock %}
